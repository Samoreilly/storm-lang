

proc int main() {
    sum: int = 0;

    for(i: int = 0; i < 100000; i++) {
        a: int = 1;
        b: int = 2;
        c: int = 3;
        d: int = 4;
        e: int = 5;
        f: int = 6;
        g: int = 7;
        h: int = 8;
        j: int = 9;
        k: int = 10;

        sum = a * b + c * d + e * f + g * h + j * k;
    }

    echo(sum);
}
