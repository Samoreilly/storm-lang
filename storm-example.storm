

storm Node {
    x: int;
    y: int;
};



proc void main() {

    n : Node{1, 2};

    echo(n.y);
    n.y = 5;
    echo(n.y);

    x: int = fib(500000000);
    echo(x);

}

proc int fib(n: int) {

    a: int = 0;
    b: int = 1;

    for(i: int = 0;i < n;i++) {
        tmp: int = a + b;
        a = b;
        b = tmp;
    }

    return a;
    
}
